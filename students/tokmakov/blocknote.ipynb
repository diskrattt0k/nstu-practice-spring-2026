   "source": [
    "data = load_iris()\n",
    "x = data.data\n",
    "y = data.target\n",
    "y = (y==0).astype(int)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 445,
   "id": "e2cbaf6f",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
